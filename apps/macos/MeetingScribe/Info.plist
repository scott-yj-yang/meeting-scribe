<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>MeetingScribe</string>
    <key>CFBundleIdentifier</key>
    <string>com.scottyang.MeetingScribe</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>MeetingScribe</string>
    <key>CFBundleDisplayName</key>
    <string>MeetingScribe</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.2.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <key>LSUIElement</key>
    <false/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>MeetingScribe records your microphone to transcribe meetings locally.</string>
    <key>NSCalendarsUsageDescription</key>
    <string>MeetingScribe reads your calendar to suggest meetings to record.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>MeetingScribe runs on-device speech recognition for the live preview.</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <!--
      App Transport Security exception.
      MeetingScribe talks to user-configured LLM endpoints:
      - Claude CLI is a subprocess, not a URLSession call (not affected by ATS)
      - Ollama runs as plain HTTP on localhost, LAN private ranges
        (192.168.x, 10.x, 172.16-31.x), CGNAT/Tailscale (100.64.0.0/10),
        or any user-specified host.
      Only NSAllowsArbitraryLoads is set — NOT NSAllowsLocalNetworking.
      When BOTH keys are true, macOS picks the more restrictive rule
      (NSAllowsLocalNetworking), which only exempts RFC 1918 (192.168/16,
      10/8, 172.16/12), .local, and unqualified hostnames. CGNAT/Tailscale
      (100.64.0.0/10) is NOT in that allowlist, so requests to Tailscale IPs
      fail with NSURLErrorDomain -1022 even though the intent was to allow
      them. NSAllowsArbitraryLoads alone is the nuclear option that actually
      works for every plain-HTTP endpoint. The network surface is strictly
      bounded by user-configured endpoints — there are no third-party HTTP
      calls in the app.
    -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>
