<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>MeetingScribe</string>
    <key>CFBundleIdentifier</key>
    <string>com.scottyang.MeetingScribe</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>MeetingScribe</string>
    <key>CFBundleDisplayName</key>
    <string>MeetingScribe</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.2.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <key>LSUIElement</key>
    <false/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>MeetingScribe records your microphone to transcribe meetings locally.</string>
    <key>NSCalendarsUsageDescription</key>
    <string>MeetingScribe reads your calendar to suggest meetings to record.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>MeetingScribe runs on-device speech recognition for the live preview.</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <!--
      App Transport Security exception.
      MeetingScribe talks to user-configured LLM endpoints:
      - Claude CLI is a subprocess, not a URLSession call (not affected by ATS)
      - Ollama runs as plain HTTP on localhost, LAN private ranges
        (192.168.x, 10.x, 172.16-31.x), CGNAT/Tailscale (100.64.0.0/10),
        or any user-specified host.
      NSAllowsLocalNetworking alone is insufficient because it only exempts
      .local mDNS and unqualified hostnames, not IP literals on private or
      CGNAT ranges. Enable NSAllowsArbitraryLoads because the network surface
      is strictly bounded by user-configured endpoints — there are no
      third-party HTTP calls in the app.
    -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
