{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for MeetingScribe",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "core:window:allow-set-theme",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-ask",
    "dialog:allow-message"
  ]
}
